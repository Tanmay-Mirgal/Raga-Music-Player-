{
  "expo": {
    "name": "Raga",
    "slug": "raga",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/riffy_logo.png",
    "scheme": "raga",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/riffy_logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.tancodex.raga",
      "icon": "./assets/images/riffy_logo.png"
    },
    "android": {
      "package": "com.tancodex.raga",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/riffy_logo.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/riffy_logo.png",
        "backgroundColor": "#000000"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/riffy_logo.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/riffy_logo.png",
          "imageWidth": 250,
          "resizeMode": "contain",
          "backgroundColor": "#000000",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "576083c6-0a0b-449e-b78f-0ed994cbe420"
      }
    }
  }
}
